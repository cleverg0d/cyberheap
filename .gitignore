*.hprof.xz

# Knowledge-graph output (generated by graphify skill). Ignore both the
# directory form (fresh `graphify build .`) and the bare name (our local
# symlink to .claude/graphify-out/). Either way it stays out of VCS.
graphify-out
graphify-out/
graphify.db
*.graphify.json

# Binaries — anchor to repo root so cmd/cyberheap/ (source) stays tracked.
/cyberheap
/cyberheap.exe
/bin/
/dist/

# Go
*.test
*.out
coverage.*
go.work
go.work.sum

