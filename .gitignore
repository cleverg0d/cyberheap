.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Test data (большие HPROF-файлы не коммитим — паттерн *.hprof выше это уже покрывает)
testdata/*.hprof
testdata/*.hprof.gz
testdata/*.hprof.zip
